DATABASE_URL=postgres://postgres:hydrant@localhost:5432/hydrants
CRON_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CHECKOUT_SUCCESS_URL=
CHECKOUT_CANCEL_URL=

# Road routing provider (for /api/hydrants/nearest). Set ONE of these for
# reliable routing; if both are empty the free, rate-limited OSRM demo server
# is used. ORS takes priority over Mapbox when both are set.
#   OpenRouteService key: https://openrouteservice.org/dev/#/signup (free, no card)
#   Mapbox access token:  https://account.mapbox.com/access-tokens/ (free tier)
ORS_API_KEY=
MAPBOX_TOKEN=
# Optional: point at a self-hosted OSRM instead of the public demo server.
OSRM_URL=
