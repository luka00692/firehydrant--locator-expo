# Hobby plan caps a deployment at 12 serverless functions; this repo has 20 route
# files under api/. Excluding the lowest-priority routes here until the API is
# consolidated (see README TODO) or the account is upgraded to Pro.
# Using ?id? instead of [id] because backslash-escaped brackets aren't honored
# by Vercel's ignore matcher (verified via `vercel build` + inspecting .vercel/output).
api/checkout/index.js
api/webhooks/stripe.js
api/cron/resync.js
api/geocode.js
api/groups/?id?/requests.js
api/groups/?id?/vehicles.js
api/memberships/?id?.js
api/vehicles/?id?.js
